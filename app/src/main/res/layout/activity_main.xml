<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_emerald">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark_emerald"
            android:elevation="4dp"
            app:titleTextColor="@color/text_dark_theme">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/toolbar_brand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/toolbar_logo"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="App Logo"
                        android:src="@drawable/tradeanalyst" />

                    <TextView
                        android:id="@+id/toolbar_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/colorPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerInParent="true"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Settings"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    app:tint="@color/colorPrimary" />

            </RelativeLayout>
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Main Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Chart Card Container -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/surface_dark_emerald">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:paddingHorizontal="4dp">

                            <TextView
                                android:id="@+id/chart_symbol"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BTC / USD"
                                android:textColor="@color/text_dark_theme"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/chart_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="$67,525.40"
                                android:textColor="@color/colorPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <!-- Timeframe Interval Selectors -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="12dp"
                            android:gravity="center">

                            <Button
                                android:id="@+id/btn_interval_1m"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="2dp"
                                android:padding="0dp"
                                android:text="1m"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary_dark"
                                app:strokeColor="@color/surface_dark_emerald" />

                            <Button
                                android:id="@+id/btn_interval_5m"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="2dp"
                                android:padding="0dp"
                                android:text="5m"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary_dark"
                                app:strokeColor="@color/surface_dark_emerald" />

                            <Button
                                android:id="@+id/btn_interval_15m"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="2dp"
                                android:padding="0dp"
                                android:text="15m"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary_dark"
                                app:strokeColor="@color/surface_dark_emerald" />

                            <Button
                                android:id="@+id/btn_interval_1h"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="2dp"
                                android:padding="0dp"
                                android:text="1h"
                                android:textSize="11sp"
                                android:textColor="@color/colorPrimary"
                                app:strokeColor="@color/colorPrimary" />

                            <Button
                                android:id="@+id/btn_interval_1d"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="2dp"
                                android:padding="0dp"
                                android:text="1D"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary_dark"
                                app:strokeColor="@color/surface_dark_emerald" />
                        </LinearLayout>

                        <!-- CandlestickChartView -->
                        <com.tradeanalyst.app.CandlestickChartView
                            android:id="@+id/candlestick_chart"
                            android:layout_width="match_parent"
                            android:layout_height="280dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Indicator Controllers Panel -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/surface_dark_emerald">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Technical Indicator Layers"
                            android:textColor="@color/colorPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:layout_marginBottom="8dp"/>

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="2"
                            android:useDefaultMargins="true">

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/checkbox_ema20"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:text="EMA (20) - Blue"
                                android:checked="true"
                                android:textColor="@color/text_secondary_dark" />

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/checkbox_sma20"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:text="SMA (20) - Orange"
                                android:checked="true"
                                android:textColor="@color/text_secondary_dark" />

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/checkbox_bb"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:text="Bollinger Bands (20, 2)"
                                android:checked="true"
                                android:textColor="@color/text_secondary_dark" />

                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/checkbox_sr"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:text="Support &amp; Resistance"
                                android:checked="true"
                                android:textColor="@color/text_secondary_dark" />
                        </GridLayout>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/checkbox_hide_all"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Hide All Indicators (Clean View)"
                            android:checked="false"
                            android:textColor="@color/text_secondary_dark"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Live Indicators and Stats Panel -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/surface_dark_emerald">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calculated Local Metrics"
                            android:textColor="@color/colorPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3"
                            android:layout_marginBottom="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RSI (14)"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary_dark" />
                                <TextView
                                    android:id="@+id/stat_rsi"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="54.3 (Neutral)"
                                    android:textStyle="bold"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_dark_theme" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Trend S/R"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary_dark" />
                                <TextView
                                    android:id="@+id/stat_trend"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Bullish EMA"
                                    android:textStyle="bold"
                                    android:textSize="13sp"
                                    android:textColor="@color/colorPrimary" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Active Alerts"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary_dark" />
                                <TextView
                                    android:id="@+id/stat_alerts"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 configured"
                                    android:textStyle="bold"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_dark_theme" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Fast Price Alert Threshold Maker -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Alert Target Price ($)"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/input_alert_price"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal"
                                    android:textColor="@color/text_dark_theme"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <Button
                                android:id="@+id/btn_create_alert"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Set Alert"
                                style="?attr/materialButtonStyle"/>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SwipeRefresh with Feed List Tabs (Real-Time News and Paper Trading Logs) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:layout_marginBottom="72dp"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/surface_dark_emerald">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <!-- Tab Header buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@color/surface_dark_emerald"
                            android:padding="4dp">
                            
                            <Button
                                android:id="@+id/btn_tab_news"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Market Feed"
                                style="?attr/borderlessButtonStyle"
                                android:textColor="@color/colorPrimary"/>
                            
                            <Button
                                android:id="@+id/btn_tab_trades"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="AI Auto Trades"
                                style="?attr/borderlessButtonStyle"
                                android:textColor="@color/text_secondary_dark"/>
                        </LinearLayout>

                        <!-- Loading Swipe List -->
                        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                            android:id="@+id/swipe_refresh"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/feed_recycler_view"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="8dp"
                                android:scrollbars="vertical" />
                        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Floating Recording CTA for Voice Assistant Sheet -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_voice_assistant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Voice assistant"
        android:src="@android:drawable/ic_btn_speak_now"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/bg_dark_emerald" />

    <!-- =========================================================================
     * HEADLESS BACKGROUND WEBVIEW CONTAINER (0dp GPU Layer)
     * ========================================================================= -->
    <WebView
        android:id="@+id/live_agent_webview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="invisible" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
