<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="500dp"
    android:orientation="vertical"
    android:background="@color/surface_dark_emerald"
    android:padding="16dp"
    app:behavior_peekHeight="200dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- Top Drag Handle indicator bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#44ffffff"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/sheet_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Trade Assistant"
            android:textColor="@color/colorPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_clear_voice_logs"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/ic_menu_delete"
            android:contentDescription="Clear and Refresh Logs"
            app:tint="@color/text_secondary_dark"
            android:padding="4dp"/>
    </RelativeLayout>

    <TextView
        android:id="@+id/voice_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap standard microphone below &amp; trade hands-free."
        android:textColor="@color/text_secondary_dark"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <!-- Chat Logs List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/assistant_chat_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Mic triggers panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@android:color/transparent">

            <!-- Mic Circle Inner button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_sheet_mic_record"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:src="@android:drawable/ic_btn_speak_now"
                app:backgroundTint="@color/colorPrimary"
                app:tint="@color/bg_dark_emerald"
                android:contentDescription="Record speech" />
        </RelativeLayout>

        <TextView
            android:id="@+id/lbl_tap_mic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOLD TO TALK"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
